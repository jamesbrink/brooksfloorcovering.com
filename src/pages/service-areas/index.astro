---
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import Navigation from '../../components/Navigation.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Footer from '../../components/Footer.astro';
import { serviceAreas } from '../../data/service-areas';

const faqItems = [
  {
    question: 'Do you charge extra for projects outside of Glendale?',
    answer:
      'No, we do not charge travel fees for any location within the Greater Phoenix Area. Whether your project is in Scottsdale, Buckeye, Mesa, or anywhere else in the Valley, our pricing is the same. Every project starts with a free, no-obligation estimate.',
  },
  {
    question: 'How quickly can you start a project in my area?',
    answer:
      'We typically schedule projects within one to two weeks of the estimate, depending on material availability and our current workload. For urgent repairs or time-sensitive commercial projects, we do our best to accommodate faster timelines. Call us at (623) 688-8422 to discuss your schedule.',
  },
  {
    question: 'Do you serve areas outside the cities listed on this page?',
    answer:
      'Yes, we serve the entire Greater Phoenix metro area and surrounding communities. If your city is not listed above, give us a call at (623) 688-8422 and we will let you know if we can help. We regularly take on projects in Fountain Hills, Cave Creek, Queen Creek, Litchfield Park, and other Valley communities.',
  },
  {
    question: 'Can you handle both residential and commercial projects in all service areas?',
    answer:
      'Absolutely. We provide full residential and commercial flooring services in every city we serve. This includes carpet, tile, luxury vinyl plank, engineered hardwood, polished concrete, epoxy coatings, and floor preparation for homes, offices, retail spaces, restaurants, and industrial facilities.',
  },
  {
    question: 'Are you licensed to work throughout Arizona?',
    answer:
      'Yes, our Arizona Registrar of Contractors license (ROC #226840) covers work throughout the state of Arizona. We are fully licensed, bonded, and insured. Our primary service area is the Greater Phoenix Valley, where we have been operating since 1994.',
  },
];

const serviceAreasJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: 'Flooring Services - Greater Phoenix Area',
      description:
        'Professional flooring installation, repairs, and concrete services serving Phoenix, Scottsdale, Mesa, Chandler, Tempe, Gilbert, Glendale, Peoria, Surprise, Goodyear, Avondale, and Buckeye.',
      provider: {
        '@type': 'HomeAndConstructionBusiness',
        '@id': 'https://brooksfloorcovering.com/#business',
      },
      areaServed: serviceAreas.map((area) => ({
        '@type': 'City',
        name: area.city,
        containedInPlace: { '@type': 'State', name: 'Arizona' },
      })),
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: 'https://brooksfloorcovering.com/',
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Service Areas',
          item: 'https://brooksfloorcovering.com/service-areas/',
        },
      ],
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((faq) => ({
        '@type': 'Question',
        name: faq.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: faq.answer,
        },
      })),
    },
  ],
};
---

<Layout
  title="Service Areas | Flooring Installation Across the Phoenix Valley - Brooks Floor Covering"
  description="Brooks Floor Covering serves Phoenix, Scottsdale, Mesa, Chandler, Tempe, Gilbert, Glendale, Peoria, Surprise, Goodyear, Avondale, and Buckeye. Professional flooring installation since 1994."
  jsonLd={serviceAreasJsonLd}
>
  <Navigation />

  <Hero
    title="Service Areas"
    subtitle="Professional flooring services across the Greater Phoenix Valley since 1994."
    compact={true}
  />

  <Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Service Areas' }]} />

  <main>
    <!-- Arizona Landscape Banner -->
    <section class="relative h-48 md:h-64 overflow-hidden">
      <Image
        src="/images/hero-arizona-desert-saguaro.jpg"
        alt="Arizona desert landscape with saguaro cacti representing the Phoenix Valley service area"
        class="w-full h-full object-cover"
        width={1920}
        height={480}
        inferSize
        loading="eager"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-black/30 to-transparent"></div>
    </section>

    <!-- Intro + Jump Nav (combined) -->
    <section class="bg-white">
      <div class="container mx-auto px-4 py-10">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-5 gap-8 items-start">
            <div class="md:col-span-3">
              <p class="text-xs uppercase tracking-wider text-neutral-500 font-semibold mb-2">
                Greater Phoenix Area
              </p>
              <h2 class="text-2xl md:text-3xl font-bold mb-4 text-brand-dark">
                Serving the Entire Phoenix Valley
              </h2>
              <p class="text-neutral-700 leading-relaxed mb-3">
                Based in Glendale, Brooks Floor Covering has been serving homes and businesses
                across the Greater Phoenix Area since 1994. We provide professional flooring
                installation, repairs, concrete services, and specialty tile work to over a dozen
                cities throughout the Valley. Licensed, bonded, and insured (ROC #226840) with no
                travel fees anywhere in the metro area.
              </p>
              <p class="text-neutral-700 leading-relaxed">
                Whether you need <a
                  href="/services/carpet"
                  class="text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors"
                  >carpet</a
                > for a Chandler office,
                <a
                  href="/services/tile"
                  class="text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors"
                  >tile</a
                > for a Scottsdale kitchen,
                <a
                  href="/services/polished-concrete"
                  class="text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors"
                  >polished concrete</a
                > for a Mesa warehouse, or
                <a
                  href="/services/luxury-vinyl-plank"
                  class="text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors"
                  >luxury vinyl plank</a
                > for a Surprise home, we bring the same quality and professionalism to every project.
                <a
                  href="/contact"
                  class="text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors"
                  >Contact us</a
                > for a free estimate.
              </p>
            </div>
            <div class="md:col-span-2 bg-neutral-50 rounded-xl p-5 border border-neutral-200">
              <p class="text-xs font-semibold text-neutral-500 uppercase tracking-wider mb-3">
                12 Cities Served
              </p>
              <div class="flex flex-wrap gap-2">
                {
                  serviceAreas.map((area) => (
                    <a
                      href={`/service-areas/${area.slug}/`}
                      class:list={[
                        'px-3 py-1.5 rounded-full text-sm font-medium transition-all duration-200',
                        area.highlight
                          ? 'bg-brand-primary text-white hover:bg-brand-primary-dark'
                          : 'bg-white text-neutral-600 border border-neutral-200 hover:border-brand-primary/30 hover:text-brand-primary',
                      ]}
                    >
                      {area.city}
                    </a>
                  ))
                }
              </div>
              <p class="text-xs text-neutral-400 mt-3">No travel fees within the metro area</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- City Sections -->
    <section class="py-12 bg-neutral-50">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {
              serviceAreas.map((area) => (
                <a
                  href={`/service-areas/${area.slug}/`}
                  class:list={[
                    'block rounded-xl p-6 shadow-sm border transition-shadow duration-300 hover:shadow-md scroll-mt-20',
                    area.highlight
                      ? 'bg-gradient-to-br from-brand-primary/5 to-brand-accent/5 border-brand-primary/20 md:col-span-2'
                      : 'bg-white border-neutral-200',
                  ]}
                >
                  <div class="flex items-start justify-between gap-4 mb-3">
                    <div>
                      <h3 class="text-xl font-bold text-brand-dark">
                        {area.city}
                        <span class="text-sm font-normal text-neutral-400 ml-1">, AZ</span>
                      </h3>
                      <p class="text-sm text-brand-accent font-medium">{area.tagline}</p>
                    </div>
                    {area.highlight && (
                      <span class="shrink-0 bg-brand-primary text-white text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider">
                        Home Base
                      </span>
                    )}
                  </div>
                  <p class="text-neutral-700 leading-relaxed mb-4">{area.description}</p>
                  <div class="flex flex-wrap gap-4 text-sm">
                    <div>
                      <span class="text-neutral-400 font-medium">Neighborhoods: </span>
                      <span class="text-neutral-600">{area.neighborhoods.join(' \u00b7 ')}</span>
                    </div>
                  </div>
                  <div class="flex flex-wrap items-center gap-2 mt-3 pt-3 border-t border-neutral-100">
                    <span class="text-xs text-neutral-400 font-semibold uppercase tracking-wider">
                      Popular:
                    </span>
                    {area.popularServices.map((service) => (
                      <span class="inline-block bg-neutral-100 text-neutral-700 text-xs font-medium px-2.5 py-1 rounded-full">
                        {service}
                      </span>
                    ))}
                    <span class="ml-auto text-sm font-semibold text-brand-primary">
                      View details &rarr;
                    </span>
                  </div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Services Available -->
    <section class="py-14 bg-white">
      <div class="container mx-auto px-4">
        <div class="max-w-5xl mx-auto">
          <div class="text-center mb-12">
            <p class="text-xs uppercase tracking-wider text-neutral-500 font-semibold mb-3">
              What We Offer
            </p>
            <h2 class="text-3xl md:text-4xl font-bold text-brand-dark">
              Services Available in Every City
            </h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
            <a
              href="/services/carpet"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🏠</span>
              <span class="font-medium text-neutral-800">Carpet Flooring</span>
            </a>
            <a
              href="/services/tile"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">◻️</span>
              <span class="font-medium text-neutral-800">Tile Flooring</span>
            </a>
            <a
              href="/services/luxury-vinyl-plank"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🪵</span>
              <span class="font-medium text-neutral-800">Luxury Vinyl Plank</span>
            </a>
            <a
              href="/services/engineered-hardwood"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🪵</span>
              <span class="font-medium text-neutral-800">Engineered Hardwood</span>
            </a>
            <a
              href="/services/polished-concrete"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">💎</span>
              <span class="font-medium text-neutral-800">Polished Concrete</span>
            </a>
            <a
              href="/services/epoxy"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🔬</span>
              <span class="font-medium text-neutral-800">Epoxy Flooring</span>
            </a>
            <a
              href="/services/floor-preparation"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🔧</span>
              <span class="font-medium text-neutral-800">Floor Preparation</span>
            </a>
            <a
              href="/services/custom-tile-showers"
              class="flex items-center gap-3 p-4 bg-neutral-50 rounded-lg border border-neutral-200 hover:shadow-md hover:border-brand-primary/30 transition-all duration-300"
            >
              <span class="text-2xl" aria-hidden="true">🚿</span>
              <span class="font-medium text-neutral-800">Custom Tile Showers</span>
            </a>
          </div>
          <div class="text-center mt-8">
            <a
              href="/services"
              class="inline-block text-brand-primary font-semibold hover:text-brand-primary-dark transition-colors text-lg"
            >
              View All Services &rarr;
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-14 bg-neutral-50">
      <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
          <div class="text-center mb-12">
            <p class="text-xs uppercase tracking-wider text-neutral-500 font-semibold mb-3">
              Common Questions
            </p>
            <h2 class="text-3xl md:text-4xl font-bold text-brand-dark">Service Area FAQ</h2>
          </div>
          <div class="space-y-8">
            {
              faqItems.map((faq) => (
                <div class="bg-white rounded-lg p-6 shadow-sm border border-neutral-200">
                  <h3 class="text-lg font-semibold text-neutral-800 mb-3">{faq.question}</h3>
                  <p class="text-neutral-700 leading-relaxed">{faq.answer}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-14 bg-gradient-to-br from-brand-dark to-brand-navy text-white">
      <div class="container mx-auto px-4 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-4 font-display tracking-tight">
          Ready to Start Your Flooring Project?
        </h2>
        <p class="text-xl mb-8 max-w-2xl mx-auto opacity-90">
          No matter where you are in the Phoenix Valley, our team is ready to deliver professional
          flooring results. Get started with a free, no-obligation estimate today.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/contact"
            class="inline-block bg-brand-accent text-white px-10 py-4 rounded-lg font-semibold hover:bg-brand-accent-dark transition duration-300 text-lg shadow-lg"
          >
            Get Your Free Estimate
          </a>
          <a
            href="tel:+16236888422"
            class="inline-block bg-white/10 text-white px-10 py-4 rounded-lg font-semibold hover:bg-white/20 transition duration-300 text-lg border border-white/30"
          >
            Call (623) 688-8422
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
